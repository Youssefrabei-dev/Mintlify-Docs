{
	"$schema": "https://mintlify.com/docs.json",
	"theme": "mint",
	"name": "Sawa Docs",
	"colors": {
		"primary": "#16A34A",
		"light": "#22C55E",
		"dark": "#15803D"
	},
	"favicon": "/favicon.svg",
	"icons": {
		"library": "lucide"
	},
	"navigation": {
		"languages": [
			{
				"language": "en",
				"tabs": [
					{
						"tab": "Documentation",
						"icon": "book-open",
						"groups": [
							{
								"group": "Start here",
								"icon": "rocket",
								"pages": [
									"en/index",
									"en/start-here/overview",
									"en/start-here/local-setup",
									"en/start-here/project-map",
									"en/start-here/new-developer-checklist"
								]
							},
							{
								"group": "Tutorials",
								"icon": "route",
								"pages": [
									"en/tutorials/run-backend-locally",
									"en/tutorials/first-authenticated-request",
									"en/tutorials/add-your-first-endpoint"
								]
							},
							{
								"group": "Concepts",
								"icon": "network",
								"pages": [
									{
										"group": "Architecture",
										"pages": [
											"en/concepts/architecture/overview",
											"en/concepts/architecture/request-lifecycle",
											"en/concepts/architecture/backend-layering",
											"en/concepts/architecture/authentication",
											"en/concepts/architecture/api-contract",
											"en/concepts/architecture/database-model",
											"en/concepts/architecture/events-workflow",
											"en/concepts/architecture/deployment-topology"
										]
									}
								]
							},
							{
								"group": "How-to guides",
								"icon": "wrench",
								"pages": [
									{
										"group": "Backend",
										"pages": [
											"en/how-to/backend/add-route-controller-model",
											"en/how-to/backend/add-openapi-dto",
											"en/how-to/backend/update-database-schema",
											"en/how-to/backend/add-environment-variable",
											"en/how-to/backend/debug-authenticated-route"
										]
									},
									{
										"group": "Contract",
										"pages": [
											"en/how-to/contract/publish-api-contract",
											"en/how-to/contract/mark-route-mobile-hidden"
										]
									},
									{
										"group": "Operations",
										"pages": [
											"en/how-to/ops/run-migrations",
											"en/how-to/ops/inspect-liam-erd",
											"en/how-to/ops/seed-local-data"
										]
									}
								]
							},
							{
								"group": "Reference",
								"icon": "book",
								"pages": [
									"en/reference/backend/commands",
									"en/reference/backend/environment",
									"en/reference/backend/project-layout",
									"en/reference/backend/file-responsibilities",
									"en/reference/backend/error-model",
									"en/reference/backend/middleware"
								]
							},
							{
								"group": "Later phases",
								"icon": "layers",
								"pages": ["en/mobile/overview", "en/ux/overview"]
							}
						]
					},
					{
						"tab": "API Reference",
						"icon": "square-terminal",
						"openapi": "openAPI.json"
					}
				]
			},
			{
				"language": "ar",
				"pages": [
					{
						"group": "البدء",
						"pages": ["ar/index"]
					}
				]
			}
		]
	},
	"api": {
		"openapi": "openAPI.json",
		"playground": {
			"display": "interactive",
			"proxy": true
		},
		"examples": {
			"languages": ["bash", "javascript", "python"],
			"defaults": "all",
			"prefill": false,
			"autogenerate": true
		},
		"mdx": {
			"server": "http://localhost:8080",
			"auth": {
				"method": "bearer"
			}
		}
	},
	"logo": {
		"light": "/logo/light.svg",
		"dark": "/logo/dark.svg"
	},
	"navbar": {
		"links": [
			{
				"label": "Backend API",
				"href": "/en/start-here/overview"
			}
		],
		"primary": {
			"type": "button",
			"label": "API Reference",
			"href": "/api-reference"
		}
	},
	"search": {
		"prompt": "Search Sawa documentation..."
	},
	"contextual": {
		"options": ["copy", "view", "cursor", "download-pdf"]
	},
	"footer": {
		"socials": {}
	}
}
